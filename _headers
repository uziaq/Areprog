# ============================================================
#  AREPROG — Netlify _headers  (version corrigée)
# ============================================================

# ── Sécurité globale ────────────────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# ── CSP globale (site principal) ────────────────────────────
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://identity.netlify.com https://*.googleapis.com https://*.gstatic.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.netlify.com https://*.netlify.app https://*.googleapis.com https://*.gstatic.com https://www.gstatic.com; frame-src 'none'; object-src 'none'

# ── CSP pour /simulateur (OLSX iframe) ──────────────────────
/simulateur
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://identity.netlify.com https://api.olsx.eu https://*.googleapis.com https://*.gstatic.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.olsx.eu https://*.netlify.com https://*.netlify.app https://*.googleapis.com https://*.gstatic.com https://www.gstatic.com; frame-src https://identity.netlify.com https://api.olsx.eu; object-src 'none'

