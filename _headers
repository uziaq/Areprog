# ============================================================
#  AREPROG — Netlify _headers
#  À placer à la RACINE du repo
# ============================================================

# ── Sécurité globale ────────────────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# ── CSP globale (site principal) ────────────────────────────
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://identity.netlify.com https://*.googleapis.com https://*.gstatic.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://identity.netlify.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.netlify.com https://*.netlify.app https://*.googleapis.com; frame-src https://identity.netlify.com; object-src 'none'

# ── CSP étendue pour /gestion (EmailJS, Firebase, OLSX, jsPDF) ──
/gestion
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://identity.netlify.com https://api.olsx.eu https://*.googleapis.com https://*.gstatic.com https://www.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://identity.netlify.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; connect-src 'self' https://api.olsx.eu https://*.netlify.com https://*.netlify.app https://api.anthropic.com https://*.googleapis.com https://*.firebaseio.com https://*.firestore.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://api.emailjs.com; frame-src https://identity.netlify.com https://api.olsx.eu; object-src 'none'; worker-src 'self' blob:

# ── Cache statique ───────────────────────────────────────────
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=86400

/*.js
  Cache-Control: public, max-age=86400

# ── Pas d'indexation sur les pages privées ──────────────────
/gestion.html
  X-Robots-Tag: noindex, nofollow

/gestion
  X-Robots-Tag: noindex, nofollow

/boutique.html
  X-Robots-Tag: noindex, nofollow

/produit.html
  X-Robots-Tag: noindex, nofollow

/confirmation.html
  X-Robots-Tag: noindex, nofollow
